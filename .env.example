# Delta Chat WebPreview Bot Configuration Example
# Copy this file to .env and configure the values

# Comma-separated list of allowed bot emails (optional)
ALLOWED_BOT_EMAILS=

# Jina AI Reader API Key (optional, increases rate limits for r.jina.ai from 20 req/min to 500+ req/min)
JINA_API_KEY=
# Optional dedicated proxy for Jina AI Reader requests (e.g. http://127.0.0.1:8118)
JINA_PROXY_URL=

# Proxy Configuration (optional, routes specific domains through a proxy)
# E.g., http://127.0.0.1:8118 or socks5://127.0.0.1:9050
PROXY_URL=
# Comma-separated list of domain suffixes to route via proxy (defaults to .ru)
PROXY_DOMAINS=.ru

# KaraKeep Integration (optional, admin-only bookmarks)
KARAKEEP_URL=
KARAKEEP_API_KEY=
# Optional comma-separated list of tags to automatically attach to saved bookmarks (e.g. deltachat)
KARAKEEP_TAGS=

# Storage and cleanup settings (optional)
# Local message retention duration in seconds (default: 3600 / 1 hour)
DELETE_DEVICE_AFTER=3600
# Automatic download limit for incoming attachments in bytes (default: 1 / disable)
DOWNLOAD_LIMIT=1

